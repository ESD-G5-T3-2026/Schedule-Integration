# Default listen port is 6502 (override with PORT).
# PORT=6502

# Default IANA timezone when request body omits `timezone` (Singapore UTC+8).
# DEFAULT_TIMEZONE=Asia/Singapore

# Optional — public Timeful URLs are defaulted in src/timefulDefaults.js (not secrets).
# TIMEFUL_API_URL=https://timeful.app/api/events
# TIMEFUL_API_BASE=https://timeful.app/api
# TIMEFUL_PUBLIC_BASE_URL=https://timeful.app

# Set to "true" to enable OpenAPI/Swagger UI (slower cold start).
# ENABLE_SWAGGER=true
